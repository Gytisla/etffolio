# ETFfolio local configuration
# Copy to .env and fill in your values

# Price data source: yfinance | alpha_vantage | both
PRICE_SOURCE=both

# Alpha Vantage API key (free: https://www.alphavantage.co/support/#api-key)
# Only needed if PRICE_SOURCE is alpha_vantage or both
ALPHA_VANTAGE_KEY=

# Auto-fetch interval in hours (1-24)
UPDATE_INTERVAL=6

# Display currency
CURRENCY=EUR

# Logging: debug | info | warning | error
LOG_LEVEL=info

# Server port
PORT=8099
